{
  "version": 2,
  "resource_types": [
    {"type": "images",          "suffixes": [".png",".jpg",".jpeg",".gif",".webp",".bmp",".tiff",".tif",".ico",".heic",".heif",".svg",".pdf"]},
    {"type": "fonts",           "suffixes": [".ttf",".otf",".ttc",".woff",".woff2"]},
    {"type": "nib_storyboard",  "suffixes": [".xib",".nib",".storyboard",".storyboardc"]},
    {"type": "audio",           "suffixes": [".mp3",".wav",".m4a",".aac",".caf"]},
    {"type": "video",           "suffixes": [".mp4",".mov",".m4v"]},
    {"type": "data",            "suffixes": [".json",".xml",".bin"]},
    {"type": "strings",         "suffixes": [".strings",".stringsdict"]},
    {"type": "scripts",         "suffixes": [".js",".css",".html"]},
    {"type": "mlmodel",         "suffixes": [".mlmodel",".mlmodelc"]},
    {"type": "coredata",        "suffixes": [".mom",".momd",".omo"]},
    {"type": "metal_shader",    "suffixes": [".metal",".metallib"]},
    {"type": "package_assets",  "suffixes": [".imageset",".colorset",".dataset",".appiconset",".launchimage",".mlpackage",".scnassets"]}
  ],
  "resource_scanner": {
    "skip_directories": [".git","DerivedData","build","Carthage","node_modules",".swiftpm","__pycache__",".app",".xcarchive",".xcodeproj",".xcworkspace"]
  },
  "unused_code": {
    "skip_directories": [".git","DerivedData","build",".build","node_modules","__pycache__","Target Support Files","Pods",".svn",".hg"]
  }
}
